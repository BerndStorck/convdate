#! /bin/sed -f
#
# convdate 2.1.1 — Convert German dates to YYYY/MM/DD.
# Policy: Converts only existing digits; double‑digit years remain double‑digit.
#
# History:   2018-05-25, 2026-06-29
# Author:    Bernd Storck
# Contact:   https://www.facebook.com/BStLinux/
# License:   GNU General Public License 3.0
#
# This script is a pure sed filter. It performs no interpretation,
# assumes no century, and transforms only what is present.

# -------------------- Month names --------------------
# Replaces month names by numbers independent of the fact,
# if the first letter is in upper or lower case:
s/[Jj]anuar/01./
s/[Ff]ebruar/02./
s/[Mm]ärz/03./
s/[Mm]aerz/03./
s/[Aa]pril/04./
s/[Mm]ai/05./
s/[Jj]uni/06./
s/[Jj]uli/07./
s/[Aa]ugust/08./
s/[Ss]eptember/09./
s/[Oo]ktober/10./
s/[Nn]ovember/11./
s/[Dd]ezember/12./

# -------------------- Abbreviations --------------------
# Same as before, but for the common German month abbreviations:
s/[Jj]an\./01./
s/[Ff]eb\./02./
s/[Aa]pr\./04./
s/[Jj]un\./06./
s/[Jj]ul\./07./
s/[Aa]ug\./08./
s/[Ss]ept\./09./
s/[Oo]kt\./10./
s/[Nn]ov\./11./
s/[Dd]ez\./12./

# -------------------- Cleanup --------------------
s/[\t ]//g  					# Deletes spaces and tabs.

# -------------------- Zero padding --------------------

# Day:  D. → 0D.
# # Inserts 0 before day number, if it's a single digit.
s/^\([0-9]\)\./0\1./

# Month: .M. → .0M.
# Adds 0 before month number, if it's a single digit.
s/\.\([0-9]\)\./.0\1./

# -------------------- Reorder --------------------
# TT.MM.YY(YY) → YY(YY)/MM/TT
# Inverts number sequence, "1.2.3" becomes "3/2/1".
s:\([0-9][0-9]*\)\.\([0-9][0-9]*\)\.\([0-9][0-9]*\):\3/\2/\1:
